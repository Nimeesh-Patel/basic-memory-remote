# Copy to .env and fill in. .env is gitignored — never commit real secrets.
# BASE_URL is the Tailscale Funnel URL (fill AFTER `tailscale funnel` gives it).
BASE_URL=https://YOUR-MACHINE.YOUR-TAILNET.ts.net
GH_CLIENT_ID=your_github_oauth_app_client_id
GH_CLIENT_SECRET=your_github_oauth_app_client_secret
ALLOWED_GITHUB_USER=Nimeesh-Patel
# Optional overrides:
# BACKEND_URL=http://127.0.0.1:8000/mcp
# PROXY_HOST=127.0.0.1
# PROXY_PORT=8080
